#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/proc/cygdrive/d/budget-tracker/Budget-Tracker-backend/node_modules/.pnpm/cssmin@0.3.2/node_modules/cssmin/bin/node_modules:/proc/cygdrive/d/budget-tracker/Budget-Tracker-backend/node_modules/.pnpm/cssmin@0.3.2/node_modules/cssmin/node_modules:/proc/cygdrive/d/budget-tracker/Budget-Tracker-backend/node_modules/.pnpm/cssmin@0.3.2/node_modules:/proc/cygdrive/d/budget-tracker/Budget-Tracker-backend/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/proc/cygdrive/d/budget-tracker/Budget-Tracker-backend/node_modules/.pnpm/cssmin@0.3.2/node_modules/cssmin/bin/node_modules:/proc/cygdrive/d/budget-tracker/Budget-Tracker-backend/node_modules/.pnpm/cssmin@0.3.2/node_modules/cssmin/node_modules:/proc/cygdrive/d/budget-tracker/Budget-Tracker-backend/node_modules/.pnpm/cssmin@0.3.2/node_modules:/proc/cygdrive/d/budget-tracker/Budget-Tracker-backend/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../cssmin/bin/cssmin" "$@"
else
  exec node  "$basedir/../cssmin/bin/cssmin" "$@"
fi
